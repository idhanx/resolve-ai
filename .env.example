# ──────────────────────────────────────────────
# ResolveAI — Root Environment Template
# Copy this to .env and fill in your values.
# ──────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
# Accepts: postgresql:// or postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# DistilBERT classifier sidecar (optional — backend falls back gracefully)
AI_SERVICE_URL=http://localhost:9000/predict

# Frontend API URL — set to your deployed backend domain in production
VITE_API_URL=http://localhost:8000

# SQLAlchemy query logging (set true only for debugging)
DB_ECHO=false
